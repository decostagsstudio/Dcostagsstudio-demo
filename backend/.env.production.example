NODE_ENV=production
PORT=10000
SERVE_FRONTEND=true

# Public frontend origins allowed to call the API.
# Example: https://dcostagsstudio-demo.vercel.app,https://dcostagsstudio-demo-cve78f5xi-dcostagsstudio.vercel.app,https://dcostagsstudio.com,https://www.dcostagsstudio.com
CORS_ORIGIN=https://dcostagsstudio-demo.vercel.app,https://dcostagsstudio-demo-cve78f5xi-dcostagsstudio.vercel.app,https://dcostagsstudio.com,https://www.dcostagsstudio.com

# Enable when Express runs behind nginx, Caddy, a cloud load balancer, or another reverse proxy.
TRUST_PROXY=true

# Use the production database connection string.
# Add sslmode=require when your PostgreSQL provider requires TLS.
DATABASE_URL=postgres://user:password@host:5432/dcosta_store?sslmode=require

# Replace with a generated secret of at least 32 characters.
JWT_SECRET=replace_with_a_long_random_secret_32_chars_minimum
JWT_EXPIRES_IN=8h

# Cloudinary stores product image binaries. PostgreSQL only stores returned URLs.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=dcosta/products
IMAGE_UPLOAD_MAX_MB=8

# Optional order notification webhook for Make/Zapier/custom email service.
STORE_PUBLIC_URL=https://dcostagsstudio-demo.vercel.app
ORDER_NOTIFICATION_WEBHOOK_URL=
ORDER_NOTIFICATION_WEBHOOK_SECRET=
ORDER_NOTIFICATION_TO_EMAIL=pedidos@dcostagsstudio.com

# Set when running npm run db:seed-admin in production.
SEED_DIRECTOR_EMAIL=director@dcostagsstudio.com
SEED_DIRECTOR_PASSWORD=replace_with_a_strong_initial_admin_password
SEED_DIRECTOR_NAME=Direccion
