NODE_ENV=development
PORT=4000
SERVE_FRONTEND=true
TRUST_PROXY=false
CORS_ORIGIN=http://localhost:4000,http://localhost:4173,http://127.0.0.1:4173,file://,null
STORE_PUBLIC_URL=http://localhost:4000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
